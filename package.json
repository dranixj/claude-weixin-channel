{
  "name": "claude-weixin-channel",
  "version": "0.3.2",
  "description": "WeChat channel for Claude Code via iLink Bot API — fork of cc-wechat with planned hook-based UX enhancements",
  "type": "module",
  "bin": {
    "claude-weixin-channel": "dist/cli.js",
    "claude-weixin-channel-server": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "hooks",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "claude-code",
    "mcp",
    "wechat",
    "weixin",
    "channel",
    "ilink"
  ],
  "author": "dranixj <npm@dranixj.com>",
  "license": "MIT",
  "homepage": "https://github.com/dranixj/claude-weixin-channel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dranixj/claude-weixin-channel.git"
  },
  "bugs": {
    "url": "https://github.com/dranixj/claude-weixin-channel/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "typescript": "^5.7.0"
  }
}
